# sneakerhead/.env

# PostgreSQL
POSTGRES_USER=sneaker
POSTGRES_PASSWORD=sneakerpass123

# Per-service Database URLs
USER_DATABASE_URL=postgresql+asyncpg://sneaker:sneakerpass123@postgres:5432/userdb
PRODUCT_DATABASE_URL=postgresql+asyncpg://sneaker:sneakerpass123@postgres:5432/productdb
ORDER_DATABASE_URL=postgresql+asyncpg://sneaker:sneakerpass123@postgres:5432/orderdb

# Auth (shared by user-service and order-service)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Inter-service URLs (Docker service names = K8s service names)
USER_SERVICE_URL=http://user-service:8001
PRODUCT_SERVICE_URL=http://product-service:8002

# Frontend
VITE_API_URL=/api/v1

# Gateway
GATEWAY_PORT=80

# Logging
LOG_LEVEL=info
