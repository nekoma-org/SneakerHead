# sneakerhead/.env (separated databases)

# PostgreSQL - User DB
USER_POSTGRES_USER=sneaker
USER_POSTGRES_PASSWORD=sneakerpass123
USER_POSTGRES_DB=userdb

# PostgreSQL - Product DB
PRODUCT_POSTGRES_USER=sneaker
PRODUCT_POSTGRES_PASSWORD=sneakerpass123
PRODUCT_POSTGRES_DB=productdb

# PostgreSQL - Order DB
ORDER_POSTGRES_USER=sneaker
ORDER_POSTGRES_PASSWORD=sneakerpass123
ORDER_POSTGRES_DB=orderdb

# Per-service Database URLs (each points to its own postgres instance)
USER_DATABASE_URL=postgresql+asyncpg://sneaker:sneakerpass123@user-postgres:5432/userdb
PRODUCT_DATABASE_URL=postgresql+asyncpg://sneaker:sneakerpass123@product-postgres:5432/productdb
ORDER_DATABASE_URL=postgresql+asyncpg://sneaker:sneakerpass123@order-postgres:5432/orderdb

# Auth (shared by user-service and order-service)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Inter-service URLs (Docker service names = K8s service names)
USER_SERVICE_URL=http://user-service:8001
PRODUCT_SERVICE_URL=http://product-service:8002

# Frontend
VITE_API_URL=/api/v1

# Gateway
GATEWAY_PORT=80

# Logging
LOG_LEVEL=info
